# PostgreSQL
POSTGRES_USER=haroteru_user
POSTGRES_PASSWORD=haroteru_password
POSTGRES_DB=haroteru_db
DATABASE_URL=postgres://haroteru_user:haroteru_password@localhost:5432/haroteru_db?sslmode=disable

# Backend
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
FRONTEND_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8080
# Dev-only fallback sign-in for staging/debugging
DEV_AUTH_ENABLED=false
DEV_AUTH_CODE=your-dev-auth-code
DEV_AUTH_EMAIL=dev-signin@haroteru.local
DEV_AUTH_NAME=検証ユーザー

# Frontend
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_GA_MEASUREMENT_ID=
BACKEND_URL=http://backend:8080
